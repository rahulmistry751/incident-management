{
  "name": "incident-management-backend",
  "version": "1.0.0",
  "description": "Fastify backend for Incident Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@google/genai": "^2.10.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^4.5.1",
    "openai": "^6.45.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.23.8"
  },
  "overrides": {
    "fastify": "$fastify"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/node": "^20.14.9",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.6.0"
  }
